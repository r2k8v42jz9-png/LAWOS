# ──────────────────────────────────────────────────────────────────
# LawOS environment
# ──────────────────────────────────────────────────────────────────

# Which data adapter the app reads from.
#   mock      → hand-authored demo data (default, no setup needed)
#   obsidian  → reads markdown from your vault (future; falls back to mock
#               until lib/obsidian/obsidian-adapter.ts is implemented)
LAWOS_ADAPTER=mock

# Absolute path to the Obsidian vault (used only when LAWOS_ADAPTER=obsidian).
# LAWOS_VAULT_PATH="/Users/you/Documents/Law Journey 2026-2030"
