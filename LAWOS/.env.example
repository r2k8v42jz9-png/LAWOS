# ──────────────────────────────────────────────────────────────────
# LawOS → Obsidian Local REST API
# Copy to `.env.local` and fill in your key. Never commit real keys.
# ──────────────────────────────────────────────────────────────────

# Base URL of the "Local REST API" Obsidian plugin.
# The plugin serves HTTPS on 27124 with a self-signed cert (default below).
# If you enabled the insecure HTTP server, use http://127.0.0.1:27123 instead.
OBSIDIAN_API_URL=https://127.0.0.1:27124

# The API key shown in the Local REST API plugin settings (required).
OBSIDIAN_API_KEY=

# Display name for the vault (shown in Settings only).
OBSIDIAN_VAULT_NAME=Law Journey 2026–2030

# Accept the plugin's self-signed certificate on localhost (1 = yes, default).
# Set to 0 only if you front the API with a real certificate.
OBSIDIAN_INSECURE_TLS=1
