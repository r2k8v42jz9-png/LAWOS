{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LawOS",
  "version": "1.0.0",
  "identifier": "com.lawos.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "http://127.0.0.1:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LawOS",
        "width": 1280,
        "height": 832,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "An operating system for your law journey.",
    "longDescription": "LawOS is a desktop dashboard for academic, legal and professional life — powered by your Obsidian vault.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone": "server"
    }
  }
}
